---
import { countries } from '../data/countries';
import CountryCard from './CountryCard.astro';
---

<div class="explorer-container">
  <!-- Search & Filters Panel -->
  <div class="filter-panel glass">
    <div class="search-box-wrapper">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-icon"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="explorer-search" class="form-input" placeholder="Search by country name..." aria-label="Search countries"/>
    </div>
    
    <div class="filter-options">
      <div class="filter-group">
        <label for="filter-status" class="filter-label">Employment Status</label>
        <select id="filter-status" class="form-select">
          <option value="all">All Statuses</option>
          <option value="Employed">Employed (Contract)</option>
          <option value="Fellowship">Fellowship (Borsa)</option>
          <option value="Student">Student Status</option>
        </select>
      </div>

      <div class="filter-group">
        <label for="filter-region" class="filter-label">Region</label>
        <select id="filter-region" class="form-select">
          <option value="all">All Regions</option>
          <option value="Central Europe">Central Europe</option>
          <option value="Western Europe">Western Europe</option>
          <option value="Northern Europe">Northern Europe</option>
          <option value="Southern Europe">Southern Europe</option>
        </select>
      </div>

      <div class="filter-group">
        <label for="filter-language" class="filter-label">Language Level</label>
        <select id="filter-language" class="form-select">
          <option value="all">All Language profiles</option>
          <option value="english-friendly">English Only Friendly (8+)</option>
          <option value="local-required">Local Language Needed</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Country Grid -->
  <div class="explorer-grid grid-3" id="country-grid">
    {countries.map((country) => (
      <div class="grid-item-wrapper" data-status={country.status} data-region={country.region} data-english={country.englishFriendly} data-name={country.name.toLowerCase()}>
        <CountryCard country={country} />
      </div>
    ))}
  </div>

  <!-- No Results State -->
  <div id="explorer-no-results" class="no-results glass" style="display: none;">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="no-results-icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M8 11h6"/></svg>
    <h3>No PhD Systems Match Your Selection</h3>
    <p>Try loosening your search terms or expanding filter options.</p>
  </div>

  <!-- Detailed PhD Passport Modal -->
  <div id="passport-modal" class="modal-overlay" style="display: none;">
    <div class="modal-content glass">
      <button class="modal-close-btn" id="modal-close" aria-label="Close details">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>

      <div class="modal-body" id="modal-body-content">
        <!-- Rendered Dynamically in JS -->
      </div>
    </div>
  </div>
</div>



<style>
  .explorer-container {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 40px;
  }
  
  .filter-panel {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  
  .search-box-wrapper {
    position: relative;
    width: 100%;
  }
  
  .search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }
  
  #explorer-search {
    padding-left: 48px;
    height: 48px;
    font-size: 1.05rem;
    border-radius: var(--radius-md);
  }
  
  .filter-options {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  
  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  
  .filter-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .form-select {
    height: 42px;
    cursor: pointer;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%239ca3af' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 12px center;
    background-repeat: no-repeat;
    background-size: 20px;
    padding-right: 40px;
    appearance: none;
  }
  
  .no-results {
    padding: 60px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }
  
  .no-results-icon {
    color: var(--text-muted);
  }
  
  /* Modal Styles */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    animation: fadeIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  .modal-content {
    position: relative;
    width: 100%;
    max-width: 900px;
    max-height: 90vh;
    overflow-y: auto;
    border-radius: var(--radius-lg);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
    animation: scaleUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  .modal-close-btn {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    width: 38px;
    height: 38px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition-fast);
    z-index: 10;
  }
  
  .modal-close-btn:hover {
    background: rgba(255, 255, 255, 0.12);
    transform: rotate(90deg);
  }

  /* Modal Details Inner CSS */
  .passport-header {
    display: flex;
    gap: 20px;
    align-items: center;
    border-bottom: 1px solid var(--border-color);
    padding: 30px;
    background: linear-gradient(135deg, var(--bg-tertiary), transparent);
  }
  
  .passport-flag {
    font-size: 3.5rem;
    line-height: 1;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.25));
  }
  
  .passport-identity {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  
  .passport-name {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text-primary);
  }
  
  .passport-meta-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  
  .passport-body {
    padding: 30px;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  
  .passport-section-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 8px;
  }
  
  .academic-text {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }
  
  .pro-con-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  
  .pro-list, .con-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid var(--border-color);
    padding: 16px;
    border-radius: var(--radius-md);
  }
  
  .pro-list h4, .con-list h4 {
    margin-bottom: 8px;
    font-size: 1rem;
  }
  
  .pro-list h4 { color: var(--success); }
  .con-list h4 { color: var(--accent); }
  
  .modal-list-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 0.9rem;
  }
  
  .modal-list-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }
  
  .modal-list-icon-pro { color: var(--success); }
  .modal-list-icon-con { color: var(--accent); }
  
  .budget-stats-summary {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  
  @media (min-width: 600px) {
    .budget-stats-summary {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  .b-stat-box {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    padding: 12px;
    border-radius: var(--radius-sm);
    text-align: center;
  }
  
  .b-stat-val {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  
  .b-stat-lbl {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 600;
  }
  
  .modal-warnings-wrapper {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .passport-actions {
    display: flex;
    gap: 16px;
    padding: 0 30px 30px;
    flex-wrap: wrap;
    border-top: 1px solid var(--border-color);
    padding-top: 24px;
    background: linear-gradient(0deg, var(--bg-tertiary), transparent);
  }
  
  .passport-actions .btn {
    flex-grow: 1;
  }

  @media (min-width: 768px) {
    .filter-options {
      grid-template-columns: repeat(3, 1fr);
    }
    .pro-con-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<script>
  import { countries } from '../data/countries';

  // Modal references
  const modal = document.getElementById('passport-modal');
  const modalClose = document.getElementById('modal-close');
  const modalBody = document.getElementById('modal-body-content');

  // Search & Filter state
  const searchInput = document.getElementById('explorer-search') as HTMLInputElement;
  const filterStatus = document.getElementById('filter-status') as HTMLSelectElement;
  const filterRegion = document.getElementById('filter-region') as HTMLSelectElement;
  const filterLanguage = document.getElementById('filter-language') as HTMLSelectElement;
  const gridItems = document.querySelectorAll('.grid-item-wrapper');
  const noResults = document.getElementById('explorer-no-results');

  // Filter Logic
  function applyFilters() {
    const searchVal = searchInput?.value.toLowerCase().trim() || '';
    const statusVal = filterStatus?.value || 'all';
    const regionVal = filterRegion?.value || 'all';
    const languageVal = filterLanguage?.value || 'all';
    
    let visibleCount = 0;

    gridItems.forEach(item => {
      const htmlItem = item as HTMLElement;
      const name = htmlItem.getAttribute('data-name') || '';
      const status = htmlItem.getAttribute('data-status') || '';
      const region = htmlItem.getAttribute('data-region') || '';
      const english = parseInt(htmlItem.getAttribute('data-english') || '0', 10);
      
      const matchesSearch = name.includes(searchVal);
      const matchesStatus = statusVal === 'all' || status === statusVal;
      const matchesRegion = regionVal === 'all' || region === regionVal;
      
      let matchesLanguage = true;
      if (languageVal === 'english-friendly') {
        matchesLanguage = english >= 8;
      } else if (languageVal === 'local-required') {
        matchesLanguage = english < 8;
      }

      if (matchesSearch && matchesStatus && matchesRegion && matchesLanguage) {
        htmlItem.style.display = 'block';
        visibleCount++;
      } else {
        htmlItem.style.display = 'none';
      }
    });

    if (noResults) {
      noResults.style.display = visibleCount === 0 ? 'flex' : 'none';
    }
  }

  // Event Listeners for Filters
  searchInput?.addEventListener('input', applyFilters);
  filterStatus?.addEventListener('change', applyFilters);
  filterRegion?.addEventListener('change', applyFilters);
  filterLanguage?.addEventListener('change', applyFilters);

  // Modal Open Logic
  function openModal(countryId: string) {
    const country = countries.find(c => c.id === countryId);
    if (!country) return;

    // Generate Modal Content
    if (modalBody) {
      modalBody.innerHTML = `
        <div class="passport-header">
          <span class="passport-flag" aria-hidden="true">${country.flag}</span>
          <div class="passport-identity">
            <h2 class="passport-name">${country.name}</h2>
            <div class="passport-meta-row">
              <span class="badge badge-primary">${country.status} Contract</span>
              <span class="badge badge-secondary">${country.region}</span>
              <span class="badge badge-success">Happiness: ${country.happinessIndex}/10</span>
            </div>
          </div>
        </div>

        <div class="passport-body">
          <!-- Academic Standing -->
          <div class="passport-section">
            <h3 class="passport-section-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="title-icon"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M6 6h10M6 10h10"/></svg>
              Academic Environment
            </h3>
            <p class="academic-text">${country.academicReputation}</p>
          </div>

          <!-- Overview -->
          <div class="passport-section">
            <h3 class="passport-section-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="title-icon"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              PhD System & Financials Overview
            </h3>
            <p class="academic-text">${country.overview}</p>
          </div>

          <!-- Pros and Cons -->
          <div class="passport-section">
            <h3 class="passport-section-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="title-icon"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
              Pros & Cons
            </h3>
            <div class="pro-con-grid">
              <div class="pro-list">
                <h4>Advantages</h4>
                ${country.pros.map(pro => `
                  <div class="modal-list-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="modal-list-icon modal-list-icon-pro"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>${pro}</span>
                  </div>
                `).join('')}
              </div>
              <div class="con-list">
                <h4>Drawbacks</h4>
                ${country.cons.map(con => `
                  <div class="modal-list-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="modal-list-icon modal-list-icon-con"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    <span>${con}</span>
                  </div>
                `).join('')}
              </div>
            </div>
          </div>

          <!-- Financial Framework -->
          <div class="passport-section">
            <h3 class="passport-section-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="title-icon"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              Financial Architecture
            </h3>
            <div class="budget-stats-summary">
              <div class="b-stat-box">
                <span class="b-stat-val">€${country.netIncome.toLocaleString()}</span>
                <span class="b-stat-lbl">Monthly Net</span>
              </div>
              <div class="b-stat-box">
                <span class="b-stat-val">€${country.costOfLiving.toLocaleString()}</span>
                <span class="b-stat-lbl">Living Costs</span>
              </div>
              <div class="b-stat-box">
                <span class="b-stat-val">${country.tuitionFeesEU === 0 ? 'Free' : `€${country.tuitionFeesEU}/yr`}</span>
                <span class="b-stat-lbl">EU Tuition</span>
              </div>
              <div class="b-stat-box">
                <span class="b-stat-val">${country.tuitionFeesNonEU === 0 ? 'Free' : `€${country.tuitionFeesNonEU.toLocaleString()}/yr`}</span>
                <span class="b-stat-lbl">Non-EU Tuition</span>
              </div>
            </div>
          </div>

          <!-- Warnings & Critical Gotchas -->
          ${country.warnings.length > 0 ? `
            <div class="passport-section">
              <h3 class="passport-section-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="title-icon"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                Critical Warnings & Alerts
              </h3>
              <div class="modal-warnings-wrapper">
                ${country.warnings.map(warning => `
                  <div class="alert-box alert-box-warning">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-top:2px; flex-shrink:0;"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    <span>${warning}</span>
                  </div>
                `).join('')}
              </div>
            </div>
          ` : ''}
        </div>

        <div class="passport-actions">
          <button class="btn btn-accent" id="modal-calc-trigger" data-id="${country.id}">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="16" height="20" x="4" y="2" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="16" y1="14" x2="16" y2="18"/><path d="M16 10h.01"/><path d="M12 10h.01"/><path d="M8 10h.01"/><path d="M12 14h.01"/><path d="M8 14h.01"/><path d="M12 18h.01"/><path d="M8 18h.01"/></svg>
            Open in Budget Calculator
          </button>
          <button class="btn btn-primary" id="modal-compare-trigger" data-id="${country.id}">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 3h5v5"/><path d="M8 21H3v-5"/><path d="M12 12 3 21"/><path d="m19 5-7 7"/></svg>
            Add to Comparison Hub
          </button>
        </div>
      `;
    }

    if (modal) {
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden'; // Lock background scroll
    }

    // Attach click events to modal triggers
    document.getElementById('modal-calc-trigger')?.addEventListener('click', (e) => {
      const id = (e.currentTarget as HTMLButtonElement).getAttribute('data-id');
      if (id) {
        // Dispatch event to change tab to calculator and select country
        window.dispatchEvent(new CustomEvent('switch-tab', { detail: { tab: 'calculator' } }));
        window.dispatchEvent(new CustomEvent('select-calc-country', { detail: { id } }));
        closeModal();
      }
    });

    document.getElementById('modal-compare-trigger')?.addEventListener('click', (e) => {
      const id = (e.currentTarget as HTMLButtonElement).getAttribute('data-id');
      if (id) {
        window.dispatchEvent(new CustomEvent('add-compare-country', { detail: { id } }));
        // Toast style alert
        alert(`${country.name} added to comparison candidates list! Go to Comparison Hub to view.`);
      }
    });
  }

  function closeModal() {
    if (modal) {
      modal.style.display = 'none';
      document.body.style.overflow = 'auto'; // Unlock background scroll
    }
  }

  // Card click triggers
  document.querySelectorAll('.country-card').forEach(card => {
    card.addEventListener('click', (e) => {
      // Don't open modal if click was on the "Explore Details" button since it will trigger it directly anyway,
      // but let's make sure it handles both.
      const target = e.target as HTMLElement;
      const cardEl = e.currentTarget as HTMLElement;
      const id = cardEl.getAttribute('data-country-id');
      if (id) {
        openModal(id);
      }
    });
  });

  // Modal events
  modalClose?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });

  // Esc key closes modal
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeModal();
    }
  });
</script>
