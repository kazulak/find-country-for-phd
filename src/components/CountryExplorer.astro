---
import { countries } from '../data/countries';
import CountryCard from './CountryCard.astro';
---

<div class="explorer-container">
  <!-- Search & Filters Panel -->
  <div class="filter-panel glass">
    <div class="search-box-wrapper">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-icon"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="explorer-search" class="form-input" placeholder="Search by country name..." aria-label="Search countries"/>
    </div>
    
    <div class="filter-options">
      <div class="filter-group">
        <label for="filter-status" class="filter-label">Employment Status</label>
        <select id="filter-status" class="form-select">
          <option value="all">All Statuses</option>
          <option value="Employed">Employed (Contract)</option>
          <option value="Fellowship">Fellowship (Borsa)</option>
          <option value="Student">Student Status</option>
        </select>
      </div>

      <div class="filter-group">
        <label for="filter-region" class="filter-label">Region</label>
        <select id="filter-region" class="form-select">
          <option value="all">All Regions</option>
          <option value="Central Europe">Central Europe</option>
          <option value="Western Europe">Western Europe</option>
          <option value="Northern Europe">Northern Europe</option>
          <option value="Southern Europe">Southern Europe</option>
        </select>
      </div>

      <div class="filter-group">
        <label for="filter-language" class="filter-label">Language Level</label>
        <select id="filter-language" class="form-select">
          <option value="all">All Language profiles</option>
          <option value="english-friendly">English Only Friendly (8+)</option>
          <option value="local-required">Local Language Needed</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Country Grid -->
  <div class="explorer-grid grid-3" id="country-grid">
    {countries.map((country) => (
      <div class="grid-item-wrapper" data-status={country.status} data-region={country.region} data-english={country.englishFriendly} data-name={country.name.toLowerCase()}>
        <CountryCard country={country} />
      </div>
    ))}
  </div>

  <!-- No Results State -->
  <div id="explorer-no-results" class="no-results glass" style="display: none;">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="no-results-icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M8 11h6"/></svg>
    <h3>No PhD Systems Match Your Selection</h3>
    <p>Try loosening your search terms or expanding filter options.</p>
  </div>

</div>



<style>
  .explorer-container {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 40px;
  }
  
  .filter-panel {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  
  .search-box-wrapper {
    position: relative;
    width: 100%;
  }
  
  .search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }
  
  #explorer-search {
    padding-left: 48px;
    height: 48px;
    font-size: 1.05rem;
    border-radius: var(--radius-md);
  }
  
  .filter-options {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  
  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  
  .filter-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .form-select {
    height: 42px;
    cursor: pointer;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%239ca3af' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 12px center;
    background-repeat: no-repeat;
    background-size: 20px;
    padding-right: 40px;
    appearance: none;
  }
  
  .no-results {
    padding: 60px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }
  
  .no-results-icon {
    color: var(--text-muted);
  }
  
  /* Responsiveness */
  @media (min-width: 768px) {
    .filter-options {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<script>
  import { countries } from '../data/countries';

  // Search & Filter state
  const searchInput = document.getElementById('explorer-search') as HTMLInputElement;
  const filterStatus = document.getElementById('filter-status') as HTMLSelectElement;
  const filterRegion = document.getElementById('filter-region') as HTMLSelectElement;
  const filterLanguage = document.getElementById('filter-language') as HTMLSelectElement;
  const gridItems = document.querySelectorAll('.grid-item-wrapper');
  const noResults = document.getElementById('explorer-no-results');

  // Filter Logic
  function applyFilters() {
    const searchVal = searchInput?.value.toLowerCase().trim() || '';
    const statusVal = filterStatus?.value || 'all';
    const regionVal = filterRegion?.value || 'all';
    const languageVal = filterLanguage?.value || 'all';
    
    let visibleCount = 0;

    gridItems.forEach(item => {
      const htmlItem = item as HTMLElement;
      const name = htmlItem.getAttribute('data-name') || '';
      const status = htmlItem.getAttribute('data-status') || '';
      const region = htmlItem.getAttribute('data-region') || '';
      const english = parseInt(htmlItem.getAttribute('data-english') || '0', 10);
      
      const matchesSearch = name.includes(searchVal);
      const matchesStatus = statusVal === 'all' || status === statusVal;
      const matchesRegion = regionVal === 'all' || region === regionVal;
      
      let matchesLanguage = true;
      if (languageVal === 'english-friendly') {
        matchesLanguage = english >= 8;
      } else if (languageVal === 'local-required') {
        matchesLanguage = english < 8;
      }

      if (matchesSearch && matchesStatus && matchesRegion && matchesLanguage) {
        htmlItem.style.display = 'block';
        visibleCount++;
      } else {
        htmlItem.style.display = 'none';
      }
    });

    if (noResults) {
      noResults.style.display = visibleCount === 0 ? 'flex' : 'none';
    }
  }

  // Event Listeners for Filters
  searchInput?.addEventListener('input', applyFilters);
  filterStatus?.addEventListener('change', applyFilters);
  filterRegion?.addEventListener('change', applyFilters);
  filterLanguage?.addEventListener('change', applyFilters);
</script>
