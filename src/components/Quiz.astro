---
// Quiz.astro
---

<div class="quiz-container glass">
  <!-- Progress Bar Header -->
  <div class="quiz-header" id="quiz-header" style="display: none;">
    <div class="quiz-progress-wrapper">
      <span class="quiz-progress-text">Question <span id="current-step-num">1</span> of 5</span>
      <div class="progress-bar-bg">
        <div class="progress-bar-fill" id="quiz-progress-bar" style="width: 0%"></div>
      </div>
    </div>
  </div>

  <!-- Step 0: Welcome / Intro -->
  <div class="quiz-step active" id="step-0">
    <div class="quiz-welcome-content">
      <span class="quiz-welcome-icon">🎓</span>
      <h2>Discover Your Ideal PhD System</h2>
      <p>European doctoral programs vary wildly. Some treat you as a full employee with a high salary and pension; others treat you as a student with tuition fees and limited rights. Take this 2-minute quiz to find the country that fits your goals.</p>
      <button class="btn btn-primary btn-lg" id="start-quiz-btn">
        Start Matching Quiz
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 4px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </button>
    </div>
  </div>

  <!-- Step 1: Citizenship -->
  <div class="quiz-step" id="step-1" style="display: none;">
    <h3 class="step-title">1. What is your citizenship status?</h3>
    <p class="step-desc">This determines whether you face visa restrictions and international tuition rates.</p>
    <div class="option-grid">
      <label class="option-card glass-interactive">
        <input type="radio" name="q-citizenship" value="eu" class="quiz-radio" />
        <span class="option-title">EU / EEA / Swiss Citizen</span>
        <span class="option-desc">Free movement rights. Low or zero tuition fees in almost all countries. Easy visa-free entry.</span>
      </label>
      <label class="option-card glass-interactive">
        <input type="radio" name="q-citizenship" value="noneu" class="quiz-radio" />
        <span class="option-title">Non-EU / International Citizen</span>
        <span class="option-desc">Requires a student or employment visa. Subject to international tuition fees in the UK.</span>
      </label>
    </div>
  </div>

  <!-- Step 2: Financial Model -->
  <div class="quiz-step" id="step-2" style="display: none;">
    <h3 class="step-title">2. What is your financial priority?</h3>
    <p class="step-desc">Do you seek a high-salary contract or an affordable, low-cost-of-living location?</p>
    <div class="option-grid">
      <label class="option-card glass-interactive">
        <input type="radio" name="q-finance" value="salary" class="quiz-radio" />
        <span class="option-title">Maximizing Income (Employment)</span>
        <span class="option-desc">Treat me like a staff member. I want a contract with a high salary, pension, and standard benefits.</span>
      </label>
      <label class="option-card glass-interactive">
        <input type="radio" name="q-finance" value="living" class="quiz-radio" />
        <span class="option-title">Low Cost of Living (Affordability)</span>
        <span class="option-desc">I prefer affordable housing, cheap dining, and low expenses, even if the stipend is lower.</span>
      </label>
      <label class="option-card glass-interactive">
        <input type="radio" name="q-finance" value="tuition" class="quiz-radio" />
        <span class="option-title">Zero Tuition / Low Costs</span>
        <span class="option-desc">I want to ensure there are no tuition fees whatsoever. Safe, funded, and balanced.</span>
      </label>
    </div>
  </div>

  <!-- Step 3: Language Requirement -->
  <div class="quiz-step" id="step-3" style="display: none;">
    <h3 class="step-title">3. What is your language preference?</h3>
    <p class="step-desc">Are you willing to learn a local language for administration and daily life?</p>
    <div class="option-grid">
      <label class="option-card glass-interactive">
        <input type="radio" name="q-language" value="english" class="quiz-radio" />
        <span class="option-title">English-Only Academic Setting</span>
        <span class="option-desc">I want to communicate, research, and socialize entirely in English without needing local languages.</span>
      </label>
      <label class="option-card glass-interactive">
        <input type="radio" name="q-language" value="local" class="quiz-radio" />
        <span class="option-title">Willing to learn local languages</span>
        <span class="option-desc">I am happy to learn German, French, Spanish, or Italian to secure teaching gigs or integrate locally.</span>
      </label>
    </div>
  </div>

  <!-- Step 4: PhD Research Structure -->
  <div class="quiz-step" id="step-4" style="display: none;">
    <h3 class="step-title">4. Which academic structure do you prefer?</h3>
    <p class="step-desc">Structured cohorts with classes vs. individual self-driven research.</p>
    <div class="option-grid">
      <label class="option-card glass-interactive">
        <input type="radio" name="q-structure" value="structured" class="quiz-radio" />
        <span class="option-title">Structured PhD Program</span>
        <span class="option-desc">Cohort-based, mandatory coursework, clear milestones, and progress reviews.</span>
      </label>
      <label class="option-card glass-interactive">
        <input type="radio" name="q-structure" value="individual" class="quiz-radio" />
        <span class="option-title">Individual / Traditional PhD</span>
        <span class="option-desc">High independence, self-scheduled research, focused primarily on supervisor-candidate relationship.</span>
      </label>
      <label class="option-card glass-interactive">
        <input type="radio" name="q-structure" value="nopref" class="quiz-radio" />
        <span class="option-title">No Preference / Mixed</span>
        <span class="option-desc">I am comfortable with either a structured program or a traditional model.</span>
      </label>
    </div>
  </div>

  <!-- Step 5: Lifestyle & Climate -->
  <div class="quiz-step" id="step-5" style="display: none;">
    <h3 class="step-title">5. What is your preferred quality of life focus?</h3>
    <p class="step-desc">Choose what matters most in your daily life outside the lab.</p>
    <div class="option-grid">
      <label class="option-card glass-interactive">
        <input type="radio" name="q-lifestyle" value="wlb" class="quiz-radio" />
        <span class="option-title">High Work-Life Balance & Happiness</span>
        <span class="option-desc">Excellent welfare, parental leave, equality, and high social happiness indices (Nordics / Swiss).</span>
      </label>
      <label class="option-card glass-interactive">
        <input type="radio" name="q-lifestyle" value="climate" class="quiz-radio" />
        <span class="option-title">Warm Climate & Mediterranean Culture</span>
        <span class="option-desc">Sunny weather, active social scenes, relaxed pace, and outstanding cuisine (Spain / Italy).</span>
      </label>
      <label class="option-card glass-interactive">
        <input type="radio" name="q-lifestyle" value="prestige" class="quiz-radio" />
        <span class="option-title">Global Academic Prestige</span>
        <span class="option-desc">Focus on top-ranked university brand names, extensive alumni networks, and prestige (UK / Switzerland).</span>
      </label>
    </div>
  </div>

  <!-- Quiz Results (Hidden initially) -->
  <div class="quiz-results" id="quiz-results" style="display: none;">
    <div class="results-header">
      <span class="results-sparkle">✨</span>
      <h2>Your Top PhD Country Matches</h2>
      <p>Based on your citizenship, budget priorities, language choice, and academic goals:</p>
    </div>
    
    <div class="results-list" id="matches-output-list">
      <!-- Injected by Javascript -->
    </div>
    
    <div class="results-actions">
      <button class="btn btn-secondary" id="restart-quiz-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
        Retake Quiz
      </button>
      <button class="btn btn-primary" id="view-all-explorer-btn">
        Explore All Countries
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      </button>
    </div>
  </div>

  <!-- Step Actions (Footer controls inside quiz) -->
  <div class="quiz-footer" id="quiz-footer" style="display: none;">
    <button class="btn btn-secondary" id="prev-step-btn" disabled>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Back
    </button>
    <button class="btn btn-primary" id="next-step-btn">
      Next
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </button>
  </div>
</div>

<style>
  .quiz-container {
    padding: 40px;
    margin-bottom: 40px;
    display: flex;
    flex-direction: column;
    min-height: 480px;
  }
  
  .quiz-header {
    margin-bottom: 30px;
  }
  
  .quiz-progress-wrapper {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  
  .quiz-progress-text {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
  }
  
  .progress-bar-bg {
    height: 6px;
    background: var(--bg-tertiary);
    border-radius: var(--radius-full);
    overflow: hidden;
  }
  
  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
    width: 0%;
    border-radius: var(--radius-full);
    transition: width var(--transition-normal) ease-out;
  }
  
  .quiz-step {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    animation: fadeIn var(--transition-normal);
  }
  
  .quiz-welcome-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .quiz-welcome-icon {
    font-size: 4rem;
    line-height: 1;
  }
  
  .step-title {
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--text-primary);
  }
  
  .step-desc {
    color: var(--text-secondary);
    margin-bottom: 30px;
    font-size: 1rem;
  }
  
  .option-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  
  .option-card {
    position: relative;
    padding: 24px;
    border-radius: var(--radius-md);
    cursor: pointer;
    border: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: var(--transition-normal);
    user-select: none;
  }
  
  .option-card:hover {
    border-color: rgba(139, 92, 246, 0.3);
    background: rgba(255, 255, 255, 0.02);
  }
  
  .quiz-radio {
    position: absolute;
    top: 24px;
    right: 24px;
    accent-color: var(--primary);
    width: 18px;
    height: 18px;
  }
  
  .option-card:has(input:checked) {
    border-color: var(--primary);
    background: var(--primary-glow);
    box-shadow: 0 4px 20px var(--primary-glow);
  }
  
  .option-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  
  .option-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  
  .quiz-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border-color);
    margin-top: 40px;
    padding-top: 24px;
  }
  
  /* Results Styling */
  .quiz-results {
    animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  .results-header {
    text-align: center;
    margin-bottom: 40px;
  }
  
  .results-sparkle {
    font-size: 3rem;
    line-height: 1;
    display: inline-block;
    margin-bottom: 12px;
    filter: drop-shadow(0 0 10px rgba(251, 191, 36, 0.4));
  }
  
  .results-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 40px;
  }
  
  .result-item {
    display: flex;
    align-items: center;
    padding: 24px;
    border-radius: var(--radius-md);
    gap: 24px;
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid var(--border-color);
    position: relative;
    overflow: hidden;
  }
  
  .result-rank-num {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text-muted);
    min-width: 45px;
  }
  
  .result-flag {
    font-size: 3rem;
    line-height: 1;
  }
  
  .result-content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  
  .result-name-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  
  .result-country-name {
    font-size: 1.35rem;
    font-weight: 700;
  }
  
  .match-percentage-badge {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--primary-hover);
    font-size: 1rem;
  }
  
  .result-brief {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  
  .result-reasoning-tag {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-style: italic;
    margin-top: 4px;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  
  .result-reasoning-tag::before {
    content: "💡";
  }
  
  .results-actions {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .quiz-container {
      padding: 24px;
    }
    .result-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
    .result-rank-num {
      position: absolute;
      top: 16px;
      right: 16px;
      text-align: right;
      min-width: unset;
      font-size: 1.5rem;
    }
  }
</style>

<script>
  import { countries } from '../data/countries';
  import { calculateMatchScore } from '../../lib/score-engine.js';

  // Navigation DOM Elements
  const step0 = document.getElementById('step-0');
  const startBtn = document.getElementById('start-quiz-btn');
  const quizHeader = document.getElementById('quiz-header');
  const quizFooter = document.getElementById('quiz-footer');
  const prevBtn = document.getElementById('prev-step-btn');
  const nextBtn = document.getElementById('next-step-btn');
  const progressBar = document.getElementById('quiz-progress-bar');
  const currentStepText = document.getElementById('current-step-num');
  const resultsDiv = document.getElementById('quiz-results');
  const restartBtn = document.getElementById('restart-quiz-btn');
  const viewAllBtn = document.getElementById('view-all-explorer-btn');
  const matchesOutputList = document.getElementById('matches-output-list');

  let currentStep = 0;
  const totalSteps = 5;

  // Selected Answers State
  const answers = {
    citizenship: '',
    finance: '',
    language: '',
    structure: '',
    lifestyle: ''
  };

  function startQuiz() {
    currentStep = 1;
    answers.citizenship = '';
    answers.finance = '';
    answers.language = '';
    answers.structure = '';
    answers.lifestyle = '';
    
    // Reset checked radios
    document.querySelectorAll('.quiz-radio').forEach(radio => {
      (radio as HTMLInputElement).checked = false;
    });

    showStep(1);
    if (quizHeader) quizHeader.style.display = 'block';
    if (quizFooter) quizFooter.style.display = 'flex';
    if (step0) step0.style.display = 'none';
    if (resultsDiv) resultsDiv.style.display = 'none';
  }

  function showStep(step: number) {
    // Hide all steps
    for (let i = 0; i <= totalSteps; i++) {
      const el = document.getElementById(`step-${i}`);
      if (el) el.style.display = i === step ? 'flex' : 'none';
    }

    // Update Progress
    if (progressBar) {
      const percentage = ((step - 1) / totalSteps) * 100;
      progressBar.style.width = `${percentage}%`;
    }
    if (currentStepText) {
      currentStepText.textContent = step.toString();
    }

    // Update Footer Buttons
    if (prevBtn) {
      (prevBtn as HTMLButtonElement).disabled = step === 1;
    }
    if (nextBtn) {
      nextBtn.innerHTML = step === totalSteps 
        ? `Submit Matches <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 4px;"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>` 
        : `Next <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 4px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>`;
    }
  }

  function handleNext() {
    // Validate that an option was chosen in the current step
    const currentQuestionName = getQuestionNameForStep(currentStep);
    const checkedOption = document.querySelector(`input[name="${currentQuestionName}"]:checked`) as HTMLInputElement;

    if (!checkedOption) {
      alert("Please select one of the options to proceed.");
      return;
    }

    // Save answer
    const answerKey = currentQuestionName.replace('q-', '') as keyof typeof answers;
    answers[answerKey] = checkedOption.value;

    if (currentStep < totalSteps) {
      currentStep++;
      showStep(currentStep);
    } else {
      calculateAndShowResults();
    }
  }

  function handlePrev() {
    if (currentStep > 1) {
      currentStep--;
      showStep(currentStep);
    }
  }

  function getQuestionNameForStep(step: number): string {
    switch(step) {
      case 1: return 'q-citizenship';
      case 2: return 'q-finance';
      case 3: return 'q-language';
      case 4: return 'q-structure';
      case 5: return 'q-lifestyle';
      default: return '';
    }
  }

  function calculateAndShowResults() {
    // Standardize user answers to priority weighting preferences
    const preferences = {
      isEuStudent: answers.citizenship === 'eu',
      priorityStipend: answers.finance === 'salary' ? 5 : 3,
      priorityCostOfLiving: answers.finance === 'living' ? 5 : 3,
      priorityTuitionFees: answers.finance === 'tuition' ? 5 : 3,
      requireEnglishFriendly: answers.language === 'english',
      requireEmployeeStatus: answers.finance === 'salary',
      preferShorterDuration: answers.structure === 'individual',
      priorityHappiness: answers.lifestyle === 'wlb' ? 5 : 3,
      visaImportance: answers.lifestyle === 'prestige' ? 5 : 3
    };

    const matchedScores = countries.map(country => {
      const match = calculateMatchScore(country, preferences);
      return {
        country,
        eligible: match.eligible,
        score: match.totalScore,
        reason: match.explanation,
        warnings: match.warnings,
        confidence: match.confidence,
        affordability_risk: match.affordability_risk
      };
    });

    // Sort: eligible matches first, then by score descending, then by name alphabetically
    matchedScores.sort((a, b) => {
      if (a.eligible !== b.eligible) {
        return a.eligible ? -1 : 1;
      }
      return b.score - a.score;
    });

    // Render results list
    if (matchesOutputList) {
      matchesOutputList.innerHTML = matchedScores.map((item, idx) => {
        let confidenceClass = 'badge-danger';
        let confidenceLabel = 'Low Fit';

        if (!item.eligible) {
          confidenceClass = 'badge-danger';
          confidenceLabel = 'Disqualified';
        } else if (item.score >= 80) {
          confidenceClass = 'badge-success';
          confidenceLabel = 'High Match';
        } else if (item.score >= 60) {
          confidenceClass = 'badge-warning';
          confidenceLabel = 'Medium Match';
        }

        const scoreHTML = item.eligible 
          ? `<span class="match-percentage-badge">${item.score}% Match</span>`
          : `<span class="match-percentage-badge disqualified-badge" style="background: rgba(239, 68, 68, 0.1); color: var(--accent); border-color: var(--accent); padding: 4px 8px; border-radius: 4px; font-size: 0.8rem; font-weight: 700;">DB Failed</span>`;

        return `
          <div class="result-item glass-interactive ${item.eligible ? '' : 'disqualified-item'}" style="${item.eligible ? '' : 'opacity: 0.65;'}">
            <span class="result-rank-num">#${idx + 1}</span>
            <span class="result-flag" aria-hidden="true">${item.country.flag}</span>
            <div class="result-content">
              <div class="result-name-row">
                <h3 class="result-country-name">${item.country.name}</h3>
                <span class="badge ${confidenceClass}">${confidenceLabel}</span>
                ${scoreHTML}
              </div>
              <p class="result-brief">
                PhD Candidate Status: <strong>${item.country.status}</strong> | Net income: <strong>€${item.country.netIncome.toLocaleString()}/mo</strong> | Cost of living: <strong>~€${item.country.costOfLiving.toLocaleString()}/mo</strong>
              </p>
              <div class="result-reasoning-tag" style="margin-top: 6px;">
                <span>${item.reason}</span>
              </div>
              ${item.warnings.length > 0 ? `
                <div class="result-warnings-tag" style="margin-top: 6px; font-size: 0.8rem; color: var(--accent); display: flex; gap: 4px; align-items: center;">
                  <span>⚠️ ${item.warnings.join(' | ')}</span>
                </div>
              ` : ''}
            </div>
            <a href="/find-country-for-phd/countries/${item.country.id}/" class="btn btn-secondary btn-sm">
              View details →
            </a>
          </div>
        `;
      }).join('');
    }

    // Toggle UI blocks
    if (quizHeader) quizHeader.style.display = 'none';
    if (quizFooter) quizFooter.style.display = 'none';
    
    for (let i = 1; i <= totalSteps; i++) {
      const el = document.getElementById(`step-${i}`);
      if (el) el.style.display = 'none';
    }

    if (resultsDiv) resultsDiv.style.display = 'block';
  }

  // Bind Listeners
  startBtn?.addEventListener('click', startQuiz);
  nextBtn?.addEventListener('click', handleNext);
  prevBtn?.addEventListener('click', handlePrev);
  restartBtn?.addEventListener('click', startQuiz);
  viewAllBtn?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('switch-tab', { detail: { tab: 'explorer' } }));
  });

  // Clicking anywhere on an option card triggers the radio inside it
  document.querySelectorAll('.option-card').forEach(card => {
    card.addEventListener('click', (e) => {
      const radio = card.querySelector('input[type="radio"]') as HTMLInputElement;
      if (radio && e.target !== radio) {
        radio.checked = true;
      }
    });
  });
</script>
